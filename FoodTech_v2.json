											"",
											"pm.test(\"✅ Status changed to IN_PREPARATION\", function () {",
											"    pm.expect(task.status).to.eql('IN_PREPARATION');",
											"});",
											"",
											"pm.test(\"✅ startedAt timestamp is set\", function () {",
											"    pm.expect(task.startedAt).to.not.be.null;",
											"});",
											"",
											"pm.test(\"✅ completedAt is still null (async execution)\", function () {",
											"    pm.expect(task.completedAt).to.be.null;",
											"});",
											"",
											"pm.test(\"✅ Timestamps chronology: createdAt < startedAt\", function () {",
											"    const created = new Date(task.createdAt);",
											"    const started = new Date(task.startedAt);",
											"    pm.expect(started.getTime()).to.be.above(created.getTime());",
											"});",
											"",
											"console.log(\"⏳ Task started - waiting for auto-completion (Mono background)\");",
											"console.log(\"⏱️  Expected completion time: ~6 seconds (2 drinks × 3 sec)\");"
										],
